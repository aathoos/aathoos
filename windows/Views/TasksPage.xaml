<UserControl
  x:Class="aathoos.Views.TasksPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource AppBackgroundBrush}"
  UseLayoutRounding="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="32,28,32,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Tasks" FontSize="26" FontWeight="Bold"
                   Foreground="{StaticResource AppForegroundBrush}"/>
        <TextBlock Text="Stay on top of your deadlines" FontSize="13"
                   Foreground="{StaticResource AppMutedBrush}" Margin="0,3,0,0"/>
      </StackPanel>
      <Button x:Name="AddButton" Grid.Column="1"
              Click="OnAddClick" Style="{StaticResource AccentButton}"
              Padding="14,9" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                     VerticalAlignment="Center" Margin="0,0,7,0"/>
          <TextBlock Text="New Task" FontSize="13.5" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <Border Grid.Row="1" Background="{StaticResource AppBorderBrush}"/>

    <!-- Filter tabs -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="32,12,32,12">
      <Button x:Name="TabAll"       Click="OnFilterAll"       Padding="14,7" Margin="0,0,6,0">All</Button>
      <Button x:Name="TabActive"    Click="OnFilterActive"    Padding="14,7" Margin="0,0,6,0">Active</Button>
      <Button x:Name="TabCompleted" Click="OnFilterCompleted" Padding="14,7">Completed</Button>
    </StackPanel>

    <Border Grid.Row="3" Background="{StaticResource AppBorderBrush}"/>

    <!-- Task list -->
    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="TaskRows" Margin="24,8,24,16"/>
    </ScrollViewer>
  </Grid>
</UserControl>
