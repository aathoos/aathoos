<UserControl
  x:Class="aathoos.Views.StudyPlannerPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource AppBackgroundBrush}"
  UseLayoutRounding="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="32,28,32,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Study Planner" FontSize="26" FontWeight="Bold"
                   Foreground="{StaticResource AppForegroundBrush}"/>
        <TextBlock Text="Log sessions and track subject time" FontSize="13"
                   Foreground="{StaticResource AppMutedBrush}" Margin="0,3,0,0"/>
      </StackPanel>
      <Button x:Name="LogBtn" Grid.Column="1"
              Click="OnLogSession" Style="{StaticResource AccentButton}"
              Padding="14,9" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                     VerticalAlignment="Center" Margin="0,0,7,0"/>
          <TextBlock Text="Log Session" FontSize="13.5" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <Border Grid.Row="1" Background="{StaticResource AppBorderBrush}"/>

    <!-- Two-panel body -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280"/>
        <ColumnDefinition Width="1"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Subject totals -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                    Background="{StaticResource AppSurfaceBrush}">
        <StackPanel Margin="0,8,0,16">
          <TextBlock Text="By Subject" FontSize="12" FontWeight="SemiBold"
                     Foreground="{StaticResource AppMutedBrush}"
                     Margin="18,12,18,10"/>
          <StackPanel x:Name="SubjectTotals"/>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Column="1" Background="{StaticResource AppBorderBrush}"/>

      <!-- Right: Session history -->
      <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,28">
          <TextBlock Text="Session History" FontSize="15" FontWeight="SemiBold"
                     Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,14"/>
          <StackPanel x:Name="SessionList"/>
          <TextBlock x:Name="NoSessionsText"
                     Text="No sessions yet. Log a study session to get started."
                     FontSize="13" Foreground="{StaticResource AppMutedBrush}"
                     Visibility="Collapsed"/>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
