<UserControl
  x:Class="aathoos.Views.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource AppBackgroundBrush}"
  UseLayoutRounding="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="32,28,32,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock x:Name="GreetingText" FontSize="26" FontWeight="Bold"
                   Foreground="{StaticResource AppForegroundBrush}"/>
        <TextBlock x:Name="DateText" FontSize="13"
                   Foreground="{StaticResource AppMutedBrush}" Margin="0,3,0,0"/>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Background="{StaticResource AppBorderBrush}"/>

    <!-- Content -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="32,24,32,32">

        <!-- Stat cards -->
        <WrapPanel Margin="0,0,0,28">

          <!-- Tasks -->
          <Border Width="188" Margin="0,0,14,14" CornerRadius="12"
                  Background="{StaticResource AppSurfaceBrush}" Padding="20">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0">
                <TextBlock x:Name="TaskCountText" Text="0"
                           FontSize="40" FontWeight="Bold"
                           Foreground="{StaticResource AppForegroundBrush}"/>
                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource AppAccentBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Top"/>
              </Grid>
              <TextBlock Grid.Row="2" Text="Pending tasks" FontSize="13"
                         Foreground="{StaticResource AppMutedBrush}"/>
            </Grid>
          </Border>

          <!-- Notes -->
          <Border Width="188" Margin="0,0,14,14" CornerRadius="12"
                  Background="{StaticResource AppSurfaceBrush}" Padding="20">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0">
                <TextBlock x:Name="NoteCountText" Text="0"
                           FontSize="40" FontWeight="Bold"
                           Foreground="{StaticResource AppForegroundBrush}"/>
                <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource AppInfoBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Top"/>
              </Grid>
              <TextBlock Grid.Row="2" Text="Notes" FontSize="13"
                         Foreground="{StaticResource AppMutedBrush}"/>
            </Grid>
          </Border>

          <!-- Goals -->
          <Border Width="188" Margin="0,0,14,14" CornerRadius="12"
                  Background="{StaticResource AppSurfaceBrush}" Padding="20">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0">
                <TextBlock x:Name="GoalCountText" Text="0"
                           FontSize="40" FontWeight="Bold"
                           Foreground="{StaticResource AppForegroundBrush}"/>
                <TextBlock Text="&#xE879;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource AppWarningBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Top"/>
              </Grid>
              <TextBlock Grid.Row="2" Text="Active goals" FontSize="13"
                         Foreground="{StaticResource AppMutedBrush}"/>
            </Grid>
          </Border>

          <!-- Study -->
          <Border Width="188" Margin="0,0,14,14" CornerRadius="12"
                  Background="{StaticResource AppSurfaceBrush}" Padding="20">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0">
                <TextBlock x:Name="StudyTimeText" Text="0m"
                           FontSize="40" FontWeight="Bold"
                           Foreground="{StaticResource AppForegroundBrush}"/>
                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource AppSuccessBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Top"/>
              </Grid>
              <TextBlock Grid.Row="2" Text="Studied today" FontSize="13"
                         Foreground="{StaticResource AppMutedBrush}"/>
            </Grid>
          </Border>

        </WrapPanel>

        <!-- Two-column lower section -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="270"/>
          </Grid.ColumnDefinitions>

          <!-- Today's Tasks card -->
          <Border Grid.Column="0" CornerRadius="12"
                  Background="{StaticResource AppSurfaceBrush}" Padding="20">
            <StackPanel>
              <Grid Margin="0,0,0,14">
                <TextBlock Text="Tasks" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource AppForegroundBrush}"/>
              </Grid>
              <StackPanel x:Name="TodayTaskRows"/>
              <TextBlock x:Name="NoTasksText" Text="No pending tasks. You're all caught up!"
                         FontSize="13" Foreground="{StaticResource AppMutedBrush}"
                         Visibility="Collapsed"/>
            </StackPanel>
          </Border>

          <!-- Active Goals card -->
          <Border Grid.Column="2" CornerRadius="12"
                  Background="{StaticResource AppSurfaceBrush}" Padding="20">
            <StackPanel>
              <TextBlock Text="Active Goals" FontSize="15" FontWeight="SemiBold"
                         Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,14"/>
              <StackPanel x:Name="GoalRows"/>
              <TextBlock x:Name="NoGoalsText" Text="No goals yet. Add one in Goals."
                         FontSize="13" Foreground="{StaticResource AppMutedBrush}"
                         Visibility="Collapsed"/>
            </StackPanel>
          </Border>
        </Grid>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
