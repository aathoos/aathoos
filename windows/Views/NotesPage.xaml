<UserControl
  x:Class="aathoos.Views.NotesPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource AppBackgroundBrush}"
  UseLayoutRounding="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="32,28,32,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Notes" FontSize="26" FontWeight="Bold"
                   Foreground="{StaticResource AppForegroundBrush}"/>
        <TextBlock Text="Capture ideas and lecture notes" FontSize="13"
                   Foreground="{StaticResource AppMutedBrush}" Margin="0,3,0,0"/>
      </StackPanel>
      <Button x:Name="AddNoteBtn" Grid.Column="1"
              Click="OnAddNote" Style="{StaticResource AccentButton}"
              Padding="14,9" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                     VerticalAlignment="Center" Margin="0,0,7,0"/>
          <TextBlock Text="New Note" FontSize="13.5" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <Border Grid.Row="1" Background="{StaticResource AppBorderBrush}"/>

    <!-- Two-panel body -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280"/>
        <ColumnDefinition Width="1"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Note list -->
      <Grid Grid.Column="0" Background="{StaticResource AppSurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="NoteList" Margin="0,8,0,8"/>
        </ScrollViewer>
      </Grid>

      <Border Grid.Column="1" Background="{StaticResource AppBorderBrush}"/>

      <!-- Right: Editor -->
      <Grid Grid.Column="2">
        <!-- Empty state -->
        <StackPanel x:Name="EmptyEditorPanel"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="44"
                     Foreground="{StaticResource AppMutedBrush}" Opacity="0.3"
                     HorizontalAlignment="Center" Margin="0,0,0,14"/>
          <TextBlock Text="Select a note to start editing" FontSize="15"
                     Foreground="{StaticResource AppMutedBrush}"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Editor panel -->
        <Grid x:Name="EditorPanel" Visibility="Collapsed" Margin="32,24,32,24">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Title row -->
          <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="EditorTitle"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AppForegroundBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Button x:Name="DeleteNoteBtn" Grid.Column="1"
                    Click="OnDeleteNote" Style="{StaticResource DangerButton}"
                    Padding="10,7" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Delete" FontSize="12.5" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>

          <!-- Subject chip -->
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock x:Name="EditorSubject"
                       FontSize="12" Foreground="{StaticResource AppMutedBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <Border Grid.Row="2" Background="{StaticResource AppBorderBrush}"/>

          <!-- Body editor -->
          <TextBox x:Name="EditorBody" Grid.Row="3"
                   Style="{StaticResource MultilineTextBox}"
                   FontSize="14" Padding="0,16,0,0"
                   Background="Transparent"
                   BorderThickness="0"
                   LostFocus="OnEditorBodyLostFocus"
                   VerticalAlignment="Stretch"/>

          <!-- Last edited -->
          <TextBlock x:Name="EditorMeta" Grid.Row="4"
                     FontSize="11" Foreground="{StaticResource AppMutedBrush}"
                     Margin="0,8,0,0"/>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
