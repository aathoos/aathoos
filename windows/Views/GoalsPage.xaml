<UserControl
  x:Class="aathoos.Views.GoalsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource AppBackgroundBrush}"
  UseLayoutRounding="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="32,28,32,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Goals" FontSize="26" FontWeight="Bold"
                   Foreground="{StaticResource AppForegroundBrush}"/>
        <TextBlock Text="Track your long-term progress" FontSize="13"
                   Foreground="{StaticResource AppMutedBrush}" Margin="0,3,0,0"/>
      </StackPanel>
      <Button x:Name="AddGoalBtn" Grid.Column="1"
              Click="OnAddGoal" Style="{StaticResource AccentButton}"
              Padding="14,9" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                     VerticalAlignment="Center" Margin="0,0,7,0"/>
          <TextBlock Text="New Goal" FontSize="13.5" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <Border Grid.Row="1" Background="{StaticResource AppBorderBrush}"/>

    <!-- Goal cards -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <WrapPanel x:Name="GoalCards" Margin="28,20,28,28" Orientation="Horizontal"/>
    </ScrollViewer>
  </Grid>
</UserControl>
