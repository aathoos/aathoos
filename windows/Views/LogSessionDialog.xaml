<Window
  x:Class="aathoos.Views.LogSessionDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Log Session"
  Width="420" SizeToContent="Height"
  Background="{StaticResource AppSurfaceBrush}"
  WindowStartupLocation="CenterOwner"
  ResizeMode="NoResize"
  UseLayoutRounding="True">

  <StackPanel Margin="24,22,24,24">
    <TextBlock Text="Log Study Session" FontSize="19" FontWeight="Bold"
               Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,20"/>

    <TextBlock Text="Subject" FontSize="12" Foreground="{StaticResource AppMutedBrush}" Margin="0,0,0,5"/>
    <TextBox x:Name="SubjectBox" Margin="0,0,0,14"/>

    <TextBlock Text="Duration" FontSize="12"
               Foreground="{StaticResource AppMutedBrush}" Margin="0,0,0,5"/>
    <Grid Margin="0,0,0,14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBox x:Name="HoursBox" Text="0"/>
        <TextBlock Text="hours" FontSize="11" Foreground="{StaticResource AppMutedBrush}"
                   Margin="2,4,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="2">
        <TextBox x:Name="MinutesBox" Text="25"/>
        <TextBlock Text="minutes" FontSize="11" Foreground="{StaticResource AppMutedBrush}"
                   Margin="2,4,0,0"/>
      </StackPanel>
    </Grid>

    <TextBlock Text="Notes (optional)" FontSize="12"
               Foreground="{StaticResource AppMutedBrush}" Margin="0,0,0,5"/>
    <TextBox x:Name="NotesBox" Style="{StaticResource MultilineTextBox}"
             Height="70" Margin="0,0,0,22"/>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Click="OnCancel" Padding="16,8" Margin="0,0,8,0"/>
      <Button Content="Log Session" Click="OnLog"
              Style="{StaticResource AccentButton}" Padding="16,8"/>
    </StackPanel>
  </StackPanel>
</Window>
