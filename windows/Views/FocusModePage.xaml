<UserControl
  x:Class="aathoos.Views.FocusModePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource AppBackgroundBrush}"
  UseLayoutRounding="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="32,28,32,18">
      <TextBlock Text="Focus Mode" FontSize="26" FontWeight="Bold"
                 Foreground="{StaticResource AppForegroundBrush}"/>
      <TextBlock Text="Pomodoro timer — stay in the zone" FontSize="13"
                 Foreground="{StaticResource AppMutedBrush}" Margin="0,3,0,0"/>
    </StackPanel>

    <Border Grid.Row="1" Background="{StaticResource AppBorderBrush}"/>

    <!-- Timer area -->
    <Grid Grid.Row="2">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- Phase label -->
        <TextBlock x:Name="PhaseLabel"
                   Text="WORK SESSION"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{StaticResource AppAccentBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Ring + time overlay -->
        <Grid HorizontalAlignment="Center" Margin="0,0,0,32">
          <!-- Track ring -->
          <Ellipse Width="240" Height="240"
                   Stroke="{StaticResource AppBorderBrush}"
                   StrokeThickness="8"
                   Fill="Transparent"/>
          <!-- Progress ring -->
          <Ellipse x:Name="TimerRing"
                   Width="240" Height="240"
                   StrokeThickness="8"
                   Fill="Transparent"
                   Stroke="{StaticResource AppAccentBrush}"
                   StrokeDashArray="729 729"
                   StrokeDashOffset="0"
                   StrokeStartLineCap="Round"
                   StrokeEndLineCap="Round"
                   RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
              <RotateTransform Angle="-90"/>
            </Ellipse.RenderTransform>
          </Ellipse>
          <!-- Center text -->
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TimerText"
                       Text="25:00"
                       FontSize="52" FontWeight="Bold"
                       Foreground="{StaticResource AppForegroundBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="SessionInfoText"
                       Text="Session 1 of 4"
                       FontSize="12"
                       Foreground="{StaticResource AppMutedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Grid>

        <!-- Subject input -->
        <StackPanel Width="300" Margin="0,0,0,24">
          <TextBlock Text="Subject" FontSize="12"
                     Foreground="{StaticResource AppMutedBrush}" Margin="0,0,0,6"/>
          <TextBox x:Name="SubjectBox" Text="General"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
          <Button x:Name="StartBtn" Click="OnStartPause"
                  Style="{StaticResource AccentButton}"
                  Padding="26,12" Margin="0,0,10,0" MinWidth="110">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="StartBtnIcon" Text="&#xE768;"
                         FontFamily="Segoe MDL2 Assets" FontSize="14"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock x:Name="StartBtnText" Text="Start"
                         FontSize="15" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Click="OnReset" Padding="20,12">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="Reset" FontSize="15" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Stats -->
        <TextBlock x:Name="StatsLabel"
                   Text="0 sessions completed today"
                   FontSize="13"
                   Foreground="{StaticResource AppMutedBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
